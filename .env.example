# ============================================================
# Fleetbase (FleetOps) backend integration
# Copy to .env.local and fill in FLEETBASE_API_KEY.
# These are server-only secrets — no NEXT_PUBLIC_ prefix, so
# they are never shipped to the browser.
# ============================================================

# Base URL of the Fleetbase REST API (NOT the :4200 console).
FLEETBASE_API_URL=https://api.91.134.240.158.sslip.io

# Secret API key from Fleetbase console → Settings → API Keys.
# Looks like: flb_live_xxxxx  (or flb_test_xxxxx)
FLEETBASE_API_KEY=

# Order-config key to use for created orders. Must match the config you
# actually watch in the console (`GET /v1/order-configs` lists them) —
# leaving it empty makes Fleetbase pick its own default, which lands the
# orders in a config nobody is looking at.
FLEETBASE_ORDER_TYPE=storefront

# Optional: dispatch (start the driver search) immediately on creation.
# true (default) or false.
FLEETBASE_DISPATCH=true

# Optional: broadcast the order to every nearby available driver rather than
# waiting for a manual assignment. true (default) or false. With this off,
# a dispatched order stays driverless until someone assigns it by hand.
FLEETBASE_ADHOC=true

# Optional: ad-hoc broadcast radius in meters. Empty → Fleetbase's default.
# Drivers outside this radius of the pickup never see the order.
FLEETBASE_ADHOC_DISTANCE=

# ============================================================
# Google Maps
# All optional: leave every value empty and the app still works —
# it falls back to the mock map, the hardcoded commerce list, and
# the straight-line fee estimate.
#
# Use TWO keys (Google's own recommendation). Enable these APIs:
#   browser key → Maps JavaScript API, Places API (New)
#   server key  → Routes API
# Note "Places API (New)", not the legacy "Places API" — the legacy
# one cannot be enabled on a Cloud project created after 2025-03-01.
# ============================================================

# Browser key — SHIPPED TO THE CLIENT (NEXT_PUBLIC_ is inlined into the JS
# bundle at BUILD time, so Coolify must pass it as a Docker BUILD ARG; a
# runtime-only env var will inline as `undefined` and the map stays mocked).
# It is public by design: restrict it in Google Cloud to HTTP referrers
# (your domain + http://localhost:3000/*) and to those two APIs.
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=

# Map ID — required for Advanced Markers (the draggable pin) to render.
# Defaults to Google's DEMO_MAP_ID; set a real one (Google Maps Platform →
# Map Management) to apply your own cloud map styling.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# Server key — SECRET. No NEXT_PUBLIC_ prefix, so it never reaches the
# browser. Used only by /api/quote to compute the road distance the delivery
# fee is based on. Restrict it by IP to the deploy host.
GOOGLE_MAPS_SERVER_KEY=

# ============================================================
# Supabase (Postgres + Auth + RLS) — multi-tenant backend
# Project → Settings → API. URL + anon key are public-safe (anon key is
# meant for the browser and is gated by RLS). The service_role key is a
# SECRET that bypasses RLS — server-only, never a NEXT_PUBLIC_ var.
# ============================================================

# Public project URL, e.g. https://eaqtsdhnybujkljyovvh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (RLS-gated; safe in the browser). Must be a BUILD ARG in
# Coolify like the other NEXT_PUBLIC_ vars.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SECRET, bypasses RLS. Runtime-only. Used server-side to
# read tenant_secrets, write the orders mirror from the public page, and
# provision tenants.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# App encryption — AES-256 key protecting each tenant's Fleetbase API key
# at rest (on top of the tenant_secrets RLS lockdown). 32 bytes, base64.
# Generate: openssl rand -base64 32
# ============================================================
APP_ENCRYPTION_KEY=

# ============================================================
# Brevo — transactional email (driver "account approved" mails).
# Brevo → SMTP & API → "Clés API". SECRET, server-only. Without it the app
# falls back to Supabase's stock recovery mail (needs custom SMTP enabled).
# Sender must be a verified Brevo sender; defaults are in approval-email.ts.
# ============================================================
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
